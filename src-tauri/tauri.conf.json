{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SynapseHub",
  "version": "0.1.2-rc.1",
  "identifier": "com.synapsehub.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "dashboard",
        "title": "SynapseHub",
        "width": 440,
        "height": 520,
        "minWidth": 400,
        "minHeight": 300,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/tray.png"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4NzdBRTBBODJGQkJGRQpSV1QrdXkrbzRIcUhBMU1QOUtmMkxZTWtUOG8xaExEVnZDWWVsUmdIZ2x6N3EyeVVHWDdCZ21GVgo=",
      "endpoints": [
        "https://github.com/thierryvm/SynapseHub/releases/latest/download/latest.json"
      ]
    }
  }
}
