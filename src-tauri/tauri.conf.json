{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SynapseHub",
  "version": "0.1.0",
  "identifier": "com.synapsehub.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "dashboard",
        "title": "SynapseHub",
        "width": 380,
        "height": 480,
        "minWidth": 320,
        "minHeight": 300,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": true,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/tray.png"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJENUFBOUUxNzNBOEEzMTgKUldRWW82aHo0YWxhdmEwb2F1eTVZVVZNc3Q1SWRuczhRZzdMbjk1d0h5bDIwUTd5d2ZwaGQzeCsK",
      "endpoints": [
        "https://github.com/thierryvm/SynapseHub/releases/latest/download/latest.json"
      ]
    }
  }
}
